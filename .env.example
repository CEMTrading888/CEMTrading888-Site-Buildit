# Copy to .env in repo root and fill in (never commit .env).
# Restart Cursor after changing so MCP picks up values.

GITHUB_PERSONAL_ACCESS_TOKEN=
DIGITALOCEAN_API_TOKEN=

# Stripe — TEST MODE ONLY (Dashboard → Developers → API keys → Test mode).
# Publishable: pk_test_…   Secret: sk_test_…
# Test card: 4242 4242 4242 4242 — no real charges.
# Do NOT use pk_live_ / sk_live_ until attorney approves and you intentionally go live.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Free market data providers for the server-side data expansion work.
# Alpha Vantage auth: ?apikey=YOUR_KEY
# Twelve Data auth: ?apikey=YOUR_KEY
# CoinGecko demo auth: x-cg-demo-api-key header or ?x_cg_demo_api_key=YOUR_KEY
ALPHA_VANTAGE_KEY=
TWELVE_DATA_KEY=
COINGECKO_KEY=

# CFTC Commitment of Traders data is public and does not require a key.
CFTC_COT_BASE_URL=https://publicreporting.cftc.gov
